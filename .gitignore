# Xcode / build artifacts (project is generated by `xcodegen`)
KokoroVoice.xcodeproj/
DerivedData/
.build/
*.xcuserstate
xcuserdata/

# Info.plist / entitlements are generated by xcodegen from project.yml's
# inline `properties:` — source of truth is project.yml, so don't commit them.
App/Info.plist
App/KokoroVoice.entitlements
Extension/Info.plist
Extension/KokoroVoiceExtension.entitlements

# Large model files — re-fetch with ./download_models.sh
Resources/*.safetensors
Resources/*.npz

# macOS
.DS_Store
